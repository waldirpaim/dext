  Dext.Collections.Dict in 'Core\Dext.Collections.Dict.pas',
  Dext.Collections.Concurrent in 'Core\Dext.Collections.Concurrent.pas',
  Dext.Collections.Channels in 'Core\Dext.Collections.Channels.pas',
  Dext.Collections.Algorithms in 'Core\Dext.Collections.Algorithms.pas',
  Dext.Collections.Simd in 'Core\Dext.Collections.Simd.pas',
  Dext.Collections.Vector in 'Core\Dext.Collections.Vector.pas',
  Dext.Collections in 'Core\Dext.Collections.pas',
  Dext.Configuration.Binder in 'Core\Dext.Configuration.Binder.pas',
  Dext.Configuration.Core in 'Core\Dext.Configuration.Core.pas',
  Dext.Configuration.EnvironmentVariables in 'Core\Dext.Configuration.EnvironmentVariables.pas',
  Dext.Configuration.Interfaces in 'Core\Dext.Configuration.Interfaces.pas',
  Dext.Configuration.Json in 'Core\Dext.Configuration.Json.pas',
  Dext.DI.Comparers in 'Core\Dext.DI.Comparers.pas',
  Dext.DI.Core in 'Core\Dext.DI.Core.pas',
  Dext.DI.Extensions in 'Core\Dext.DI.Extensions.pas',
  Dext.DI.Interfaces in 'Core\Dext.DI.Interfaces.pas',
  Dext.Json in 'Core\Dext.Json.pas',
  Dext.Json.Types in 'Core\Dext.Json.Types.pas',
  Dext.Options.Extensions in 'Core\Dext.Options.Extensions.pas',
  Dext.Options in 'Core\Dext.Options.pas',
  Dext in 'Core\Dext.pas',
  Dext.Specifications.Base in 'Core\Dext.Specifications.Base.pas',
  Dext.Specifications.Evaluator in 'Core\Dext.Specifications.Evaluator.pas',
  Dext.Specifications.Fluent in 'Core\Dext.Specifications.Fluent.pas',
  Dext.Specifications.Interfaces in 'Core\Dext.Specifications.Interfaces.pas',
  Dext.Specifications.OrderBy in 'Core\Dext.Specifications.OrderBy.pas',
  Dext.Specifications.Types in 'Core\Dext.Specifications.Types.pas',
  Dext.Threading.Async in 'Core\Dext.Threading.Async.pas',
